# Spotify App Credentials (Spotify Developer Dashboard)
SPOTIFY_CLIENT_ID=tu_client_id
SPOTIFY_CLIENT_SECRET=tu_client_secret

# Debe coincidir EXACTAMENTE con Redirect URI en Spotify Dashboard.
# Recomendado para este frontend: http://localhost:5173
SPOTIFY_REDIRECT_URI=http://localhost:5173

# URL de tu frontend React/Vite
FRONTEND_URL=http://localhost:5173
